<Window x:Class="MonkeyUSStockViewer.TickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stocks" Height="180" Width="280"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        MouseDoubleClick="Window_MouseDoubleClick">
    <DockPanel Margin="8">
        <Grid DockPanel.Dock="Top"
              Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="US Stocks" />
            <CheckBox x:Name="TopmostCheckBox"
                      Grid.Column="1"
                      Margin="0,0,8,0"
                      VerticalAlignment="Center"
                      Checked="TopmostCheckBox_Changed"
                      Unchecked="TopmostCheckBox_Changed"
                      Content="Top" />
            <Button Grid.Column="2"
                    Width="72"
                    Click="SettingsButton_Click"
                    Content="Settings" />
        </Grid>

        <ListView x:Name="PricesListView"
                  BorderThickness="0"
                  ItemsSource="{Binding Rows}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8"
                          ToolTip="{Binding HoldingTooltip}"
                          ToolTipService.InitialShowDelay="150"
                          ToolTipService.ShowDuration="10000">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontWeight="SemiBold" Text="{Binding PriceText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="10" Foreground="#666666" Text="{Binding SymbolText}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontSize="10" Foreground="{Binding ChangeBrush}" Text="{Binding ChangeText}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="10" Foreground="#666666" Text="{Binding UpdatedAt}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontSize="10" Foreground="{Binding StatusBrush}" Text="{Binding Status}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Window>
